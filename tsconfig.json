{
  "compilerOptions": {
    "outDir": "./dist/",
    "noImplicitAny": true,
    "module": "es6",
    "target": "es6",
    "allowJs": true,
    "moduleResolution": "node",
    "typeRoots": [ "./types", "./node_modules/@types"],
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "incremental": true,
    "tsBuildInfoFile": "./buildcache/front-end",
    "skipLibCheck": true,
  },
  "exclude": ["node_modules", "types"],
}
