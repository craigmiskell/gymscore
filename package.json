{
  "name": "gymscore",
  "version": "0.0.1",
  "description": "Gymnastics Competition Scores and Results",
  "main": "dist/main/main.js",
  "private": true,
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron-forge start -- --use-gl=desktop",
    "package": "electron-forge package",
    "eslint": "eslint .",
    "eslintfix": "eslint . --fix",
    "mdlint": "markdownlint --ignore node_modules --ignore out .",
    "license-check": "license-checker --summary --production --onlyAllow 'MIT;Apache-2.0;GPL-3.0-or-later'",
    "make-linux": "electron-forge make",
    "make-osx": "electron-forge make -p darwin",
    "make-windows": "electron-forge make -p win32",
    "build": "webpack --mode=production --node-env=production",
    "build:dev": "webpack --mode=development",
    "build:prod": "webpack --mode=production --node-env=production",
    "watch": "webpack --watch",
    "serve": "webpack serve"
  },
  "author": {
    "name": "Craig Miskell",
    "email": "craig@stroppykitten.com"
  },
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "@babel/core": "^7.17.10",
    "@babel/preset-env": "^7.17.10",
    "@electron-forge/cli": "^6.0.0-beta.63",
    "@electron-forge/maker-deb": "^6.0.0-beta.63",
    "@electron-forge/maker-rpm": "^6.0.0-beta.63",
    "@electron-forge/maker-squirrel": "^6.0.0-beta.63",
    "@electron-forge/maker-zip": "^6.0.0-beta.63",
    "@webpack-cli/generators": "^2.4.2",
    "babel-loader": "^8.2.5",
    "bootstrap": "^5.1.3",
    "css-loader": "^6.7.1",
    "electron": "^18.2.0",
    "eslint": "^8.14.0",
    "html-webpack-plugin": "^5.5.0",
    "jquery": "^3.6.0",
    "license-checker": "^25.0.1",
    "markdownlint-cli": "^0.31.1",
    "mini-css-extract-plugin": "^2.6.0",
    "popper.js": "^1.16.1",
    "prettier": "^2.6.2",
    "style-loader": "^3.3.1",
    "webpack": "^5.72.0",
    "webpack-cli": "^4.9.2",
    "webpack-dev-server": "^4.9.0",
    "webpack-merge": "^5.8.0"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0",
    "electron-squirrel-startup": "^1.0.0"
  },
  "config": {
    "forge": {
      "packagerConfig": {},
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "gymscore"
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin"
          ]
        },
        {
          "name": "@electron-forge/maker-deb",
          "config": {}
        }
      ]
    }
  }
}
