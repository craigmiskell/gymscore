{
  "name": "gymscore",
  "version": "0.9.6",
  "description": "Gymnastics Competition Scores and Results",
  "main": "dist/main/main.js",
  "private": true,
  "scripts": {
    "test": "jest",
    "start": "rm -r dist/*; webpack && electron-forge start -- --use-gl=desktop",
    "restart": "electron-forge start -- --use-gl=desktop",
    "package": "electron-builder --dir",
    "eslint": "eslint .",
    "eslintfix": "eslint . --fix",
    "mdlint": "markdownlint --ignore node_modules --ignore out .",
    "license-check": "license-checker --summary --production --excludePrivatePackages --onlyAllow 'MIT;Apache-2.0;GPL-3.0-or-later'",
    "generate-licenses": "node scripts/generate-licenses.js",
    "make-linux": "electron-builder --linux",
    "make-osx": "electron-builder --mac",
    "make-windows": "electron-builder --win --x64",
    "build": "webpack --mode=production --node-env=production",
    "build:dev": "webpack --mode=development",
    "build:prod": "webpack --mode=production --node-env=production",
    "watch": "webpack --watch",
    "serve": "webpack serve",
    "dev": "webpack --mode=development && pnpm build-docs && concurrently -k \"webpack --watch --mode=development\" \"electron-forge start -- --use-gl=desktop\"",
    "build-docs": "scripts/build-docs.sh --html-only && cp docs/user-guide.html dist/renderer/user-guide.html",
    "release": "commit-and-tag-version && ./scripts/publish-release.sh",
    "release:minor": "commit-and-tag-version --release-as minor && ./scripts/publish-release.sh",
    "release:major": "commit-and-tag-version --release-as major && ./scripts/publish-release.sh"
  },
  "author": {
    "name": "Craig Miskell",
    "email": "craig@stroppykitten.com"
  },
  "homepage": "https://github.com/craigmiskell/gymscore",
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@electron-forge/cli": "^7.11.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/bootstrap": "^5.2.10",
    "@types/jest": "^30.0.0",
    "@types/strftime": "^0.9.8",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@webpack-cli/generators": "^2.4.2",
    "babel-loader": "^10.1.1",
    "commit-and-tag-version": "^12.7.1",
    "concurrently": "^9.2.1",
    "css-loader": "^7.1.4",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-reload": "^2.0.0-alpha.1",
    "eslint": "^10.1.0",
    "fork-ts-checker-webpack-plugin": "^7.2.11",
    "globals": "^17.4.0",
    "html-webpack-plugin": "^5.5.0",
    "jest": "^30.3.0",
    "license-checker": "^25.0.1",
    "markdownlint-cli": "^0.48.0",
    "mini-css-extract-plugin": "^2.6.0",
    "prettier": "^3.8.1",
    "style-loader": "^4.0.0",
    "thread-loader": "^4.0.4",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "typescript": "^4.6.4",
    "webpack": "^5.72.0",
    "webpack-cli": "^4.9.2",
    "webpack-dev-server": "^4.9.0",
    "webpack-merge": "^5.8.0"
  },
  "dependencies": {
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "cross-blob": "^3.0.2",
    "dexie": "^4.4.2",
    "dexie-export-import": "^4.4.0",
    "electron-is-dev": "^3.0.1",
    "jspdf": "^4.2.1",
    "strftime": "^0.10.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron"
    ]
  },
  "config": {
    "forge": {
      "packagerConfig": {},
      "makers": []
    }
  },
  "build": {
    "appId": "com.stroppykitten.gymscore",
    "productName": "gymscore",
    "directories": {
      "output": "out"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "gymscore.ico"
    ],
    "win": {
      "target": "portable",
      "icon": "gymscore.ico"
    },
    "linux": {
      "target": "deb",
      "category": "Utility"
    },
    "mac": {
      "target": "zip"
    }
  }
}
