{
  "name": "gymscore",
  "version": "0.9.4",
  "description": "Gymnastics Competition Scores and Results",
  "main": "dist/main/main.js",
  "private": true,
  "scripts": {
    "test": "jest",
    "start": "rm -r dist/*; webpack && electron-forge start -- --use-gl=desktop",
    "restart": "electron-forge start -- --use-gl=desktop",
    "package": "electron-builder --dir",
    "eslint": "eslint .",
    "eslintfix": "eslint . --fix",
    "mdlint": "markdownlint --ignore node_modules --ignore out .",
    "license-check": "license-checker --summary --production --excludePrivatePackages --onlyAllow 'MIT;Apache-2.0;GPL-3.0-or-later'",
    "generate-licenses": "node scripts/generate-licenses.js",
    "make-linux": "electron-builder --linux",
    "make-osx": "electron-builder --mac",
    "make-windows": "electron-builder --win --x64",
    "build": "webpack --mode=production --node-env=production",
    "build:dev": "webpack --mode=development",
    "build:prod": "webpack --mode=production --node-env=production",
    "watch": "webpack --watch",
    "serve": "webpack serve",
    "dev": "webpack --mode=development && concurrently -k \"webpack --watch --mode=development\" \"electron-forge start -- --use-gl=desktop\"",
    "release": "commit-and-tag-version",
    "release:minor": "commit-and-tag-version --release-as minor",
    "release:major": "commit-and-tag-version --release-as major"
  },
  "author": {
    "name": "Craig Miskell",
    "email": "craig@stroppykitten.com"
  },
  "homepage": "https://github.com/craigmiskell/gymscore",
  "license": "GPL-3.0-or-later",
  "devDependencies": {
    "@babel/core": "^7.17.10",
    "@babel/preset-env": "^7.17.10",
    "@electron-forge/cli": "^7.11.1",
    "@types/bootstrap": "^5.1.12",
    "@types/jest": "^27.5.1",
    "@types/strftime": "^0.9.8",
    "@typescript-eslint/eslint-plugin": "^5.25.0",
    "@typescript-eslint/parser": "^5.25.0",
    "@webpack-cli/generators": "^2.4.2",
    "babel-loader": "^8.2.5",
    "commit-and-tag-version": "^12.7.1",
    "concurrently": "^7.6.0",
    "css-loader": "^6.7.1",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "electron-reload": "^2.0.0-alpha.1",
    "eslint": "^8.16.0",
    "fork-ts-checker-webpack-plugin": "^7.2.11",
    "html-webpack-plugin": "^5.5.0",
    "jest": "^28.1.0",
    "license-checker": "^25.0.1",
    "markdownlint-cli": "^0.31.1",
    "mini-css-extract-plugin": "^2.6.0",
    "popper.js": "^1.16.1",
    "prettier": "^2.6.2",
    "style-loader": "^3.3.1",
    "thread-loader": "^3.0.4",
    "ts-jest": "^28.0.2",
    "ts-loader": "^9.3.0",
    "typescript": "^4.6.4",
    "webpack": "^5.72.0",
    "webpack-cli": "^4.9.2",
    "webpack-dev-server": "^4.9.0",
    "webpack-merge": "^5.8.0"
  },
  "dependencies": {
    "bootstrap": "^5.1.3",
    "bootstrap-icons": "^1.8.3",
    "cross-blob": "^3.0.1",
    "dexie": "^3.2.2",
    "dexie-export-import": "^4.1.4",
    "electron-is-dev": "^2.0.0",
    "jspdf": "^2.5.1",
    "strftime": "^0.10.3"
  },
  "config": {
    "forge": {
      "packagerConfig": {},
      "makers": []
    }
  },
  "build": {
    "appId": "com.stroppykitten.gymscore",
    "productName": "gymscore",
    "directories": {
      "output": "out"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "deb",
      "category": "Utility"
    },
    "mac": {
      "target": "zip"
    }
  }
}
